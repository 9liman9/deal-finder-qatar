---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "Qatar Restaurant Deals",
  description = "The finest tables in Doha at their best prices — live restaurant deals across Qatar, updated daily.",
  ogImage: ogImageProp,
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
// Per-page OG image (e.g. a resolved brand logo) falls back to the site icon.
const ogImage = ogImageProp
  ? new URL(ogImageProp, canonical).href
  : new URL(`${import.meta.env.BASE_URL}icon.svg`, canonical).href;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#7a1330" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}icon.svg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}icon.svg`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Qatar Deals" />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.webmanifest`} />

    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Qatar Restaurant Deals" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ar_QA" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,900&family=Outfit:wght@300;400;500;600;700&family=Cairo:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <script is:inline>
      (function () {
        try {
          const lang = localStorage.getItem("lang") || "en";
          const el = document.documentElement;
          el.lang = lang;
          el.dir = lang === "ar" ? "rtl" : "ltr";
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-cream text-ink">
    <header class="sticky top-0 z-30 border-b border-line bg-cream/90 backdrop-blur-sm">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-3.5 flex items-center justify-between gap-4">
        <a href={import.meta.env.BASE_URL} class="flex items-baseline gap-1.5 group">
          <span
            class="i18n font-display text-2xl sm:text-[1.75rem] font-semibold text-maroon leading-none"
            data-en="Qatar Deals" data-ar="عروض قطر">Qatar Deals</span>
          <span class="text-gold text-sm translate-y-[-2px]" aria-hidden="true">◆</span>
        </a>
        <button
          id="lang-toggle"
          type="button"
          class="rounded-full border border-maroon/25 text-maroon hover:bg-maroon hover:text-cream px-4 py-1.5 text-sm font-semibold transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
          data-en-aria="Switch to Arabic"
          data-ar-aria="التبديل إلى الإنجليزية"
          aria-label="Switch to Arabic"
        >
          <span id="lang-toggle-label">العربية</span>
        </button>
      </div>
    </header>

    <main class="flex-1 w-full mx-auto max-w-6xl px-4 sm:px-6 pb-10">
      <slot />
    </main>

    <footer class="border-t border-line mt-6">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <span class="gold-rule"></span>
          <span class="i18n text-sm text-ink-soft"
            data-en="Free & open-source · No personal data collected"
            data-ar="مجاني ومفتوح المصدر · لا نجمع أي بيانات شخصية"
            >Free &amp; open-source · No personal data collected</span>
        </div>
        <span class="i18n font-display italic text-ink-soft" data-en="Made for Qatar" data-ar="صُنع لقطر">Made for Qatar</span>
      </div>
    </footer>

    <!-- Language engine: swaps text, placeholders, and aria-labels; flips direction; persists -->
    <script is:inline>
      (function () {
        function applyLang(lang) {
          const el = document.documentElement;
          el.lang = lang;
          el.dir = lang === "ar" ? "rtl" : "ltr";

          document.querySelectorAll("[data-en]").forEach((node) => {
            const val = node.getAttribute("data-" + lang);
            if (val !== null) node.textContent = val;
          });
          document.querySelectorAll("[data-en-ph]").forEach((node) => {
            const val = node.getAttribute("data-" + lang + "-ph");
            if (val !== null) node.setAttribute("placeholder", val);
          });
          document.querySelectorAll("[data-en-aria]").forEach((node) => {
            const val = node.getAttribute("data-" + lang + "-aria");
            if (val !== null) node.setAttribute("aria-label", val);
          });

          const label = document.getElementById("lang-toggle-label");
          if (label) label.textContent = lang === "ar" ? "English" : "العربية";

          try {
            localStorage.setItem("lang", lang);
          } catch (e) {}
          document.dispatchEvent(new CustomEvent("langchange", { detail: { lang } }));
        }

        let current = "en";
        try {
          current = localStorage.getItem("lang") || "en";
        } catch (e) {}
        applyLang(current);

        const btn = document.getElementById("lang-toggle");
        if (btn) {
          btn.addEventListener("click", () => {
            current = document.documentElement.lang === "ar" ? "en" : "ar";
            applyLang(current);
          });
        }
      })();
    </script>

    <!-- Share: Web Share API with clipboard fallback (used by cards + deal pages) -->
    <script is:inline>
      (function () {
        let toast;
        function showToast(msg) {
          if (!toast) {
            toast = document.createElement("div");
            toast.className = "share-toast";
            document.body.appendChild(toast);
          }
          toast.textContent = msg;
          toast.classList.add("is-visible");
          clearTimeout(toast._t);
          toast._t = setTimeout(function () { toast.classList.remove("is-visible"); }, 1800);
        }
        document.addEventListener("click", function (e) {
          const el = e.target.closest("[data-share]");
          if (!el) return;
          e.preventDefault();
          const url = new URL(el.getAttribute("data-share-url") || location.href, location.href).href;
          const title = el.getAttribute("data-share-title") || document.title;
          const ar = document.documentElement.lang === "ar";
          if (navigator.share) {
            navigator.share({ title: title, url: url }).catch(function () {});
          } else if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(url)
              .then(function () { showToast(ar ? "تم نسخ الرابط" : "Link copied"); })
              .catch(function () { showToast(ar ? "تعذّر النسخ" : "Couldn’t copy"); });
          } else {
            showToast(url);
          }
        });
      })();
    </script>

    <!-- PWA: register the service worker (HTTPS / localhost only) -->
    <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register(base + "sw.js", { scope: base }).catch(() => {});
        });
      }
    </script>
  </body>
</html>

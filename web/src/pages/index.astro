---
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
// Synced from repo-root data/deals.json by scripts/sync-data.mjs (predev/prebuild).
import data from "../data/deals.json";

const MS_PER_DAY = 86_400_000;
const today = new Date();
today.setHours(0, 0, 0, 0);

function daysLeft(validTo: string | null): number | null {
  if (!validTo) return null;
  const d = new Date(validTo + "T00:00:00");
  if (isNaN(d.getTime())) return null;
  return Math.ceil((d.getTime() - today.getTime()) / MS_PER_DAY);
}

const deals = (data.deals ?? []).map((deal: any) => ({ deal, dl: daysLeft(deal.valid_to) }));
const filters = data.filters ?? { cuisines: [], areas: [], deal_types: [] };

const TYPE_LABELS: Record<string, { en: string; ar: string }> = {
  discount_pct: { en: "Discount", ar: "خصم" },
  bogo: { en: "Buy 1 Get 1", ar: "واحد + واحد" },
  set_menu: { en: "Set Menu", ar: "وجبة محددة" },
  coupon: { en: "Coupon", ar: "كوبون" },
  free_item: { en: "Freebie", ar: "هدية مجانية" },
  other: { en: "Offer", ar: "عرض" },
};

// Arabic labels for filter options (value stays the English key so filtering is stable).
const CUISINE_AR: Record<string, string> = {
  Lebanese: "لبناني", Indian: "هندي", Japanese: "ياباني", Italian: "إيطالي",
  Cafe: "مقهى", Burgers: "برجر", Seafood: "مأكولات بحرية", Healthy: "صحي",
  "Fast Casual": "وجبات سريعة",
};
const AREA_AR: Record<string, string> = {
  "The Pearl": "اللؤلؤة", "Souq Waqif": "سوق واقف", "West Bay": "الخليج الغربي",
  Lusail: "لوسيل", Msheireb: "مشيرب", Aspire: "أسباير", Katara: "كتارا",
  "Al Sadd": "السد", Corniche: "الكورنيش", "Education City": "المدينة التعليمية",
};

// Deals are aggregated from public Qatar listings (factqatar, etc.) — real but
// third-party sourced, so we show a "confirm with the restaurant" disclaimer.
const showSourceNote = true;

const selectCls =
  "rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400";

// Schema.org structured data so Google can surface the deals as rich results.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Qatar Restaurant Deals",
  numberOfItems: deals.length,
  itemListElement: deals.slice(0, 40).map(({ deal }: any, i: number) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Offer",
      name: deal.title?.en,
      url: deal.source_url || canonical,
      category: deal.deal_type,
      ...(deal.valid_to ? { validThrough: deal.valid_to } : {}),
      seller: {
        "@type": "Restaurant",
        name: deal.restaurant?.name?.en,
        ...(deal.restaurant?.area
          ? { address: { "@type": "PostalAddress", addressLocality: deal.restaurant.area, addressCountry: "QA" } }
          : {}),
      },
    },
  })),
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <section class="mb-5">
    <h1 class="i18n text-2xl sm:text-3xl font-extrabold text-brand-700"
      data-en="Find the best restaurant deals in Qatar"
      data-ar="اعثر على أفضل عروض المطاعم في قطر">Find the best restaurant deals in Qatar</h1>
    <p class="i18n text-stone-500 mt-1"
      data-en="Live offers across Doha — free, open-source, and updated automatically."
      data-ar="عروض مباشرة في الدوحة — مجانية ومفتوحة المصدر وتُحدّث تلقائياً.">Live offers across Doha — free, open-source, and updated automatically.</p>
  </section>

  {showSourceNote && (
    <div class="mb-5 rounded-xl border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-800 flex items-start gap-2">
      <span aria-hidden="true">ℹ️</span>
      <span class="i18n"
        data-en="Deals are aggregated from public Qatar listings and may change — please confirm with the restaurant before visiting."
        data-ar="تُجمع العروض من قوائم قطرية عامة وقد تتغيّر — يُرجى التأكد من المطعم قبل الزيارة.">Deals are aggregated from public Qatar listings and may change — please confirm with the restaurant before visiting.</span>
    </div>
  )}

  <!-- Filter bar -->
  <section class="mb-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    <input id="f-search" type="search"
      class="sm:col-span-2 lg:col-span-1 rounded-lg border border-stone-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400"
      data-en-ph="Search deals or restaurants…" data-ar-ph="ابحث عن العروض أو المطاعم…"
      data-en-aria="Search deals or restaurants" data-ar-aria="ابحث عن العروض أو المطاعم"
      aria-label="Search deals or restaurants"
      placeholder="Search deals or restaurants…" />

    {filters.cuisines.length > 0 && (
      <select id="f-cuisine" class={selectCls}
        data-en-aria="Filter by cuisine" data-ar-aria="تصفية حسب المطبخ" aria-label="Filter by cuisine">
        <option value="" class="i18n" data-en="All cuisines" data-ar="كل المطابخ">All cuisines</option>
        {filters.cuisines.map((c: string) => (
          <option value={c} class="i18n" data-en={c} data-ar={CUISINE_AR[c] ?? c}>{c}</option>
        ))}
      </select>
    )}

    {filters.areas.length > 0 && (
      <select id="f-area" class={selectCls}
        data-en-aria="Filter by area" data-ar-aria="تصفية حسب المنطقة" aria-label="Filter by area">
        <option value="" class="i18n" data-en="All areas" data-ar="كل المناطق">All areas</option>
        {filters.areas.map((a: string) => (
          <option value={a} class="i18n" data-en={a} data-ar={AREA_AR[a] ?? a}>{a}</option>
        ))}
      </select>
    )}

    {filters.deal_types.length > 0 && (
      <select id="f-type" class={selectCls}
        data-en-aria="Filter by deal type" data-ar-aria="تصفية حسب نوع العرض" aria-label="Filter by deal type">
        <option value="" class="i18n" data-en="All types" data-ar="كل الأنواع">All types</option>
        {filters.deal_types.map((t: string) => (
          <option value={t} class="i18n" data-en={(TYPE_LABELS[t] ?? TYPE_LABELS.other).en} data-ar={(TYPE_LABELS[t] ?? TYPE_LABELS.other).ar}>{(TYPE_LABELS[t] ?? TYPE_LABELS.other).en}</option>
        ))}
      </select>
    )}
  </section>

  <!-- Result count + reset -->
  <div class="mb-4 flex items-center justify-between text-sm">
    <span class="text-stone-500" aria-live="polite">
      <span id="result-count" class="font-bold text-brand-700">{deals.length}</span>
      <span class="i18n" data-en="deals" data-ar="عرض">deals</span>
    </span>
    <button id="f-reset" type="button" class="i18n text-stone-500 hover:text-brand-600 transition"
      data-en="Reset filters" data-ar="إعادة تعيين">Reset filters</button>
  </div>

  <!-- Grid -->
  <section id="deal-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {deals.map(({ deal, dl }: any) => <DealCard deal={deal} daysLeft={dl} />)}
  </section>

  <!-- Empty state -->
  <div id="empty-state" class="is-hidden text-center py-16 text-stone-400">
    <p class="text-4xl mb-2" aria-hidden="true">🔍</p>
    <p class="i18n" data-en="No deals match your filters." data-ar="لا توجد عروض مطابقة.">No deals match your filters.</p>
  </div>

  <!-- Client-side: defensive Qatar-time expiry + live "days left" + filtering -->
  <script is:inline>
    (function () {
      const search = document.getElementById("f-search");
      const cuisine = document.getElementById("f-cuisine");
      const area = document.getElementById("f-area");
      const type = document.getElementById("f-type");
      const reset = document.getElementById("f-reset");
      const count = document.getElementById("result-count");
      const empty = document.getElementById("empty-state");
      const cards = Array.from(document.querySelectorAll("[data-card]"));

      // "Today" anchored to Qatar (UTC+3), independent of the viewer's timezone.
      function qatarTodayUTC() {
        const d = new Date(Date.now() + 3 * 3600 * 1000);
        return Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
      }
      function dateToUTC(s) {
        const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s || "");
        return m ? Date.UTC(+m[1], +m[2] - 1, +m[3]) : null;
      }
      const todayQ = qatarTodayUTC();
      const lang = document.documentElement.lang === "ar" ? "ar" : "en";

      // Recompute expiry + the day-counter badge in the browser, so the live site
      // never shows a deal that has expired since the last build (no cron needed).
      cards.forEach((card) => {
        const vt = dateToUTC(card.dataset.validTo);
        if (vt === null) return; // ongoing
        const days = Math.round((vt - todayQ) / 86400000);
        if (days < 0) card.dataset.expired = "1";
        const badge = card.querySelector(".exp-badge");
        if (!badge) return;
        let en, ar, urgent = false;
        if (days <= 0) { en = "Ends today"; ar = "ينتهي اليوم"; urgent = true; }
        else if (days === 1) { en = "1 day left"; ar = "متبقٍّ يوم واحد"; urgent = true; }
        else { en = days + " days left"; ar = "متبقّي " + days + " يوم"; urgent = days <= 3; }
        badge.setAttribute("data-en", en);
        badge.setAttribute("data-ar", ar);
        badge.textContent = lang === "ar" ? ar : en;
        badge.classList.toggle("text-red-600", urgent);
        badge.classList.toggle("text-stone-400", !urgent);
      });

      function apply() {
        const q = (search && search.value || "").trim().toLowerCase();
        const c = cuisine ? cuisine.value : "";
        const a = area ? area.value : "";
        const t = type ? type.value : "";
        let visible = 0;
        cards.forEach((card) => {
          if (card.dataset.expired === "1") { card.classList.add("is-hidden"); return; }
          const ok =
            (!q || (card.dataset.search || "").includes(q)) &&
            (!c || card.dataset.cuisine === c) &&
            (!a || card.dataset.area === a) &&
            (!t || card.dataset.type === t);
          card.classList.toggle("is-hidden", !ok);
          if (ok) visible++;
        });
        if (count) count.textContent = String(visible);
        if (empty) empty.classList.toggle("is-hidden", visible !== 0);
      }

      [search, cuisine, area, type].forEach((el) => {
        if (!el) return;
        el.addEventListener("input", apply);
        el.addEventListener("change", apply);
      });
      if (reset) {
        reset.addEventListener("click", () => {
          if (search) search.value = "";
          if (cuisine) cuisine.value = "";
          if (area) area.value = "";
          if (type) type.value = "";
          apply();
        });
      }
      apply();
    })();
  </script>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import DealCard from "../components/DealCard.astro";
import FeaturedCarousel from "../components/FeaturedCarousel.astro";
import data from "../data/deals.json";

const MS_PER_DAY = 86_400_000;
const today = new Date();
today.setHours(0, 0, 0, 0);

function daysLeft(validTo: string | null): number | null {
  if (!validTo) return null;
  const d = new Date(validTo + "T00:00:00");
  if (isNaN(d.getTime())) return null;
  return Math.ceil((d.getTime() - today.getTime()) / MS_PER_DAY);
}

const deals = (data.deals ?? []).map((deal: any) => ({ deal, dl: daysLeft(deal.valid_to) }));
const filters = data.filters ?? { cuisines: [], areas: [], deal_types: [], channels: [] };
const count = deals.length;

const TYPE_LABELS: Record<string, { en: string; ar: string }> = {
  discount_pct: { en: "Discount", ar: "خصم" }, bogo: { en: "Buy 1 Get 1", ar: "واحد + واحد" },
  set_menu: { en: "Set Menu", ar: "وجبة محددة" }, coupon: { en: "Coupon", ar: "كوبون" },
  free_item: { en: "Freebie", ar: "هدية مجانية" }, other: { en: "Offer", ar: "عرض" },
};
const CHANNEL_LABELS: Record<string, { en: string; ar: string }> = {
  dine_in: { en: "Dine-in", ar: "في المطعم" }, delivery: { en: "Delivery", ar: "توصيل" }, both: { en: "Dine-in & Delivery", ar: "في المطعم وتوصيل" },
};
const CUISINE_AR: Record<string, string> = {
  Lebanese: "لبناني", Indian: "هندي", Japanese: "ياباني", Italian: "إيطالي", Cafe: "مقهى",
  Burgers: "برجر", Seafood: "مأكولات بحرية", Healthy: "صحي", Persian: "فارسي", Chinese: "صيني",
  Thai: "تايلندي", Turkish: "تركي", Mexican: "مكسيكي", Steakhouse: "ستيك", Chicken: "دجاج",
  International: "عالمي", "Fast Casual": "وجبات سريعة",
};
const AREA_AR: Record<string, string> = {
  "The Pearl": "اللؤلؤة", "Souq Waqif": "سوق واقف", "West Bay": "الخليج الغربي", Lusail: "لوسيل",
  Msheireb: "مشيرب", Aspire: "أسباير", Katara: "كتارا", "Al Sadd": "السد", Corniche: "الكورنيش",
  "Education City": "المدينة التعليمية", Doha: "الدوحة", "Al Wakra": "الوكرة",
};
const PRICE_BANDS = [
  { v: "0-50", en: "Under QR 50", ar: "أقل من 50 ر.ق" },
  { v: "50-100", en: "QR 50–100", ar: "50–100 ر.ق" },
  { v: "100-200", en: "QR 100–200", ar: "100–200 ر.ق" },
  { v: "200-", en: "QR 200+", ar: "200+ ر.ق" },
];

// Featured = biggest discounts + notable prices + expiring soon, one per restaurant.
const featured = (() => {
  const seen = new Set<string>();
  return [...deals]
    .map((x: any) => ({
      x,
      score: (x.deal.discount_value || 0) * 4 + Math.min((x.deal.price || 0) / 40, 6) + (x.dl !== null && x.dl <= 3 ? 6 : 0),
    }))
    .sort((a, b) => b.score - a.score)
    .filter(({ x }) => {
      const k = x.deal.restaurant?.slug || String(x.deal.id);
      if (seen.has(k)) return false;
      seen.add(k);
      return true;
    })
    .slice(0, 8)
    .map(({ x }) => x);
})();

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const jsonLd = {
  "@context": "https://schema.org", "@type": "ItemList", name: "Qatar Restaurant Deals", numberOfItems: count,
  itemListElement: deals.slice(0, 40).map(({ deal }: any, i: number) => ({
    "@type": "ListItem", position: i + 1,
    item: {
      "@type": "Offer", name: deal.title?.en, url: deal.source_url || canonical, category: deal.deal_type,
      ...(deal.valid_to ? { validThrough: deal.valid_to } : {}),
      ...(typeof deal.price === "number" ? { price: Math.round(deal.price), priceCurrency: "QAR" } : {}),
      seller: { "@type": "Restaurant", name: deal.restaurant?.name?.en,
        ...(deal.restaurant?.area ? { address: { "@type": "PostalAddress", addressLocality: deal.restaurant.area, addressCountry: "QA" } } : {}) },
    },
  })),
};

const ctrl = "rounded-full border border-line bg-bone px-4 py-2 text-sm text-ink hover:border-gold-soft focus:outline-none focus:ring-2 focus:ring-gold/50 transition-colors";
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <section class="pt-8 sm:pt-10 pb-7">
    <p class="eyebrow text-gold-deep flex items-center gap-2.5">
      <span class="gold-rule"></span>
      <span class="i18n" data-en="Doha · Dining offers" data-ar="الدوحة · عروض المطاعم">Doha · Dining offers</span>
    </p>
    <h1 class="font-display text-4xl sm:text-5xl lg:text-[3.75rem] font-semibold text-maroon leading-[1.04] mt-3.5 max-w-3xl i18n"
      data-en="The finest tables in Doha, at their best prices."
      data-ar="أرقى الموائد في الدوحة، بأفضل الأسعار.">The finest tables in Doha, at their best prices.</h1>
    <p class="mt-4 text-ink-soft text-base sm:text-lg max-w-xl i18n"
      data-en={`${count} live offers across Qatar — gathered from public listings, refreshed every day.`}
      data-ar={`${count} عرض حي في قطر — مُجمّعة من القوائم العامة، وتُحدَّث يومياً.`}>{count} live offers across Qatar — gathered from public listings, refreshed every day.</p>
  </section>

  {featured.length > 0 && <FeaturedCarousel items={featured} />}

  <!-- Source note -->
  <p class="flex items-start gap-2 text-xs text-ink-soft/80 mb-5 max-w-2xl">
    <span class="text-gold-deep" aria-hidden="true">✦</span>
    <span class="i18n" data-en="Deals are gathered from public Qatar listings and may change — please confirm with the restaurant before visiting."
      data-ar="تُجمع العروض من قوائم قطرية عامة وقد تتغيّر — يُرجى التأكد من المطعم قبل الزيارة.">Deals are gathered from public Qatar listings and may change — please confirm with the restaurant before visiting.</span>
  </p>

  <!-- Filter bar -->
  <section class="mb-5 flex flex-wrap items-center gap-2.5">
    <input id="f-search" type="search"
      class="grow min-w-[12rem] rounded-full border border-line bg-bone px-4 py-2 text-sm text-ink focus:outline-none focus:ring-2 focus:ring-gold/50"
      data-en-ph="Search restaurants or dishes…" data-ar-ph="ابحث عن المطاعم أو الأطباق…"
      data-en-aria="Search deals or restaurants" data-ar-aria="ابحث عن العروض أو المطاعم"
      aria-label="Search deals or restaurants" placeholder="Search restaurants or dishes…" />

    {filters.cuisines.length > 0 && (
      <select id="f-cuisine" class={ctrl} data-en-aria="Filter by cuisine" data-ar-aria="تصفية حسب المطبخ" aria-label="Filter by cuisine">
        <option value="" class="i18n" data-en="All cuisines" data-ar="كل المطابخ">All cuisines</option>
        {filters.cuisines.map((c: string) => <option value={c} class="i18n" data-en={c} data-ar={CUISINE_AR[c] ?? c}>{c}</option>)}
      </select>
    )}
    {filters.areas.length > 0 && (
      <select id="f-area" class={ctrl} data-en-aria="Filter by area" data-ar-aria="تصفية حسب المنطقة" aria-label="Filter by area">
        <option value="" class="i18n" data-en="All areas" data-ar="كل المناطق">All areas</option>
        {filters.areas.map((a: string) => <option value={a} class="i18n" data-en={a} data-ar={AREA_AR[a] ?? a}>{a}</option>)}
      </select>
    )}
    <select id="f-price" class={ctrl} data-en-aria="Filter by price" data-ar-aria="تصفية حسب السعر" aria-label="Filter by price">
      <option value="" class="i18n" data-en="Any price" data-ar="أي سعر">Any price</option>
      {PRICE_BANDS.map((p) => <option value={p.v} class="i18n" data-en={p.en} data-ar={p.ar}>{p.en}</option>)}
    </select>
    {filters.deal_types.length > 0 && (
      <select id="f-type" class={ctrl} data-en-aria="Filter by deal type" data-ar-aria="تصفية حسب نوع العرض" aria-label="Filter by deal type">
        <option value="" class="i18n" data-en="All types" data-ar="كل الأنواع">All types</option>
        {filters.deal_types.map((t: string) => <option value={t} class="i18n" data-en={(TYPE_LABELS[t] ?? TYPE_LABELS.other).en} data-ar={(TYPE_LABELS[t] ?? TYPE_LABELS.other).ar}>{(TYPE_LABELS[t] ?? TYPE_LABELS.other).en}</option>)}
      </select>
    )}
    {filters.channels.length > 1 && (
      <select id="f-channel" class={ctrl} data-en-aria="Filter by dine-in or delivery" data-ar-aria="تصفية حسب المكان أو التوصيل" aria-label="Filter by dine-in or delivery">
        <option value="" class="i18n" data-en="Anywhere" data-ar="في أي مكان">Anywhere</option>
        {filters.channels.map((c: string) => <option value={c} class="i18n" data-en={(CHANNEL_LABELS[c] ?? CHANNEL_LABELS.dine_in).en} data-ar={(CHANNEL_LABELS[c] ?? CHANNEL_LABELS.dine_in).ar}>{(CHANNEL_LABELS[c] ?? CHANNEL_LABELS.dine_in).en}</option>)}
      </select>
    )}
  </section>

  <!-- Active filter chips (built client-side) -->
  <div id="active-filters" class="mb-4 flex flex-wrap items-center gap-2 is-hidden"></div>

  <div class="mb-5 flex flex-wrap items-center justify-between gap-3 text-sm">
    <span class="text-ink-soft" aria-live="polite">
      <span id="result-count" class="font-display text-lg font-semibold text-maroon">{count}</span>
      <span class="i18n ms-1" data-en="offers" data-ar="عرض">offers</span>
    </span>
    <div class="flex flex-wrap items-center gap-2">
      <span class="eyebrow text-ink-soft/70 hidden sm:inline i18n" data-en="Sort" data-ar="ترتيب">Sort</span>
      <div id="sort-group" class="inline-flex rounded-full border border-line bg-bone p-0.5"
        role="group" data-en-aria="Sort offers" data-ar-aria="ترتيب العروض" aria-label="Sort offers">
        <button type="button" class="sort-btn" data-sort="ending" aria-pressed="true">
          <span class="i18n" data-en="Ending soon" data-ar="ينتهي قريباً">Ending soon</span></button>
        <button type="button" class="sort-btn" data-sort="discount" aria-pressed="false">
          <span class="i18n" data-en="Top % off" data-ar="أعلى خصم">Top % off</span></button>
        <button type="button" class="sort-btn" data-sort="price" aria-pressed="false">
          <span class="i18n" data-en="Lowest price" data-ar="الأقل سعراً">Lowest price</span></button>
        <button type="button" class="sort-btn" data-sort="surprise" aria-pressed="false">
          <span class="i18n" data-en="Surprise me" data-ar="فاجئني">Surprise me</span></button>
      </div>
      <button id="f-reset" type="button" class="i18n text-ink-soft hover:text-maroon transition-colors ms-1"
        data-en="Reset" data-ar="إعادة تعيين">Reset</button>
    </div>
  </div>

  <section id="deal-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {deals.map(({ deal, dl }: any, i: number) => <DealCard deal={deal} daysLeft={dl} index={i} />)}
  </section>

  <div id="empty-state" class="is-hidden text-center py-16 text-ink-soft">
    <p class="font-display text-3xl text-gold-soft mb-2">—</p>
    <p class="i18n" data-en="No offers match your filters." data-ar="لا توجد عروض مطابقة.">No offers match your filters.</p>
  </div>

  <!-- Client-side: Qatar-time expiry + live day-counter + filtering -->
  <script is:inline>
    (function () {
      const $ = (id) => document.getElementById(id);
      const search = $("f-search"), cuisine = $("f-cuisine"), area = $("f-area"),
        price = $("f-price"), type = $("f-type"), channel = $("f-channel"),
        reset = $("f-reset"), count = $("result-count"), empty = $("empty-state");
      const grid = $("deal-grid"), sortGroup = $("sort-group"), activeFilters = $("active-filters");
      const cards = Array.from(document.querySelectorAll("[data-card]"));

      function qatarTodayUTC() {
        const d = new Date(Date.now() + 3 * 3600 * 1000);
        return Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
      }
      function dateToUTC(s) {
        const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s || "");
        return m ? Date.UTC(+m[1], +m[2] - 1, +m[3]) : null;
      }
      const todayQ = qatarTodayUTC();
      const lang = document.documentElement.lang === "ar" ? "ar" : "en";

      cards.forEach((card) => {
        const vt = dateToUTC(card.dataset.validTo);
        if (vt === null) return;
        const days = Math.round((vt - todayQ) / 86400000);
        card.dataset.days = String(days);
        if (days < 0) card.dataset.expired = "1";
        const badge = card.querySelector(".exp-badge");
        if (!badge) return;
        let en, ar, urgent = false;
        if (days <= 0) { en = "Ends today"; ar = "ينتهي اليوم"; urgent = true; }
        else if (days === 1) { en = "1 day left"; ar = "متبقٍّ يوم واحد"; urgent = true; }
        else { en = days + " days left"; ar = "متبقّي " + days + " يوم"; urgent = days <= 3; }
        badge.setAttribute("data-en", en);
        badge.setAttribute("data-ar", ar);
        badge.textContent = lang === "ar" ? ar : en;
        badge.classList.toggle("text-red-700", urgent);
        badge.classList.toggle("text-ink-soft/80", !urgent);
      });

      function inBand(p, band) {
        if (!band) return true;
        const n = parseFloat(p);
        if (isNaN(n)) return false;
        const parts = band.split("-");
        const lo = parts[0], hi = parts[1];
        if (lo && n < +lo) return false;
        if (hi && n > +hi) return false;
        return true;
      }

      function apply() {
        const q = (search && search.value || "").trim().toLowerCase();
        const c = cuisine ? cuisine.value : "", a = area ? area.value : "",
          pr = price ? price.value : "", t = type ? type.value : "", ch = channel ? channel.value : "";
        let visible = 0;
        cards.forEach((card) => {
          if (card.dataset.expired === "1") { card.classList.add("is-hidden"); return; }
          const ok =
            (!q || (card.dataset.search || "").includes(q)) &&
            (!c || card.dataset.cuisine === c) &&
            (!a || card.dataset.area === a) &&
            (!t || card.dataset.type === t) &&
            (!ch || card.dataset.channel === ch) &&
            inBand(card.dataset.price, pr);
          card.classList.toggle("is-hidden", !ok);
          if (ok) visible++;
        });
        if (count) count.textContent = String(visible);
        if (empty) empty.classList.toggle("is-hidden", visible !== 0);
        renderChips();
      }

      // ---- Active-filter chips (removable) ----
      function renderChips() {
        if (!activeFilters) return;
        activeFilters.innerHTML = "";
        const items = [];
        if (search && search.value.trim()) items.push(['"' + search.value.trim() + '"', () => { search.value = ""; }]);
        [cuisine, area, price, type, channel].forEach((sel) => {
          if (sel && sel.value) {
            const opt = sel.options[sel.selectedIndex];
            items.push([opt ? opt.textContent.trim() : sel.value, () => { sel.value = ""; }]);
          }
        });
        items.forEach(([label, clearFn]) => {
          const chip = document.createElement("span");
          chip.className = "chip";
          const txt = document.createElement("span");
          txt.textContent = label;
          const btn = document.createElement("button");
          btn.type = "button";
          btn.setAttribute("aria-label", "Remove filter");
          btn.textContent = "✕";
          btn.addEventListener("click", () => { clearFn(); apply(); });
          chip.append(txt, btn);
          activeFilters.appendChild(chip);
        });
        activeFilters.classList.toggle("is-hidden", items.length === 0);
      }

      // ---- Sorting (reorders the grid; server already renders "ending soon") ----
      function keyOf(card, mode) {
        if (mode === "discount") { const v = card.dataset.discount ? +card.dataset.discount : null; return v == null ? Infinity : -v; }
        if (mode === "price") { const v = card.dataset.price ? +card.dataset.price : null; return v == null ? Infinity : v; }
        const d = (card.dataset.days === undefined || card.dataset.days === "") ? null : +card.dataset.days;
        return d == null ? Infinity : d; // ending soon: fewest days first, ongoing last
      }
      function sortCards(mode) {
        if (!grid) return;
        const arr = cards.slice();
        if (mode === "surprise") {
          for (let i = arr.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); const t = arr[i]; arr[i] = arr[j]; arr[j] = t; }
        } else {
          arr.sort((a, b) => keyOf(a, mode) - keyOf(b, mode));
        }
        const frag = document.createDocumentFragment();
        arr.forEach((c) => frag.appendChild(c));
        grid.appendChild(frag);
      }
      function spotlightFirst() {
        const first = cards.find((c) => !c.classList.contains("is-hidden"));
        if (!first) return;
        first.classList.remove("spotlight"); void first.offsetWidth; first.classList.add("spotlight");
        first.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
      let sortMode = "ending";
      try { sortMode = localStorage.getItem("sort") || "ending"; } catch (e) {}
      function markSort(mode) {
        if (!sortGroup) return;
        Array.from(sortGroup.querySelectorAll(".sort-btn")).forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.sort === mode)));
      }
      function setSort(mode, persist) {
        sortMode = mode;
        markSort(mode);
        if (persist) { try { localStorage.setItem("sort", mode); } catch (e) {} }
        sortCards(mode);
        if (mode === "surprise") spotlightFirst();
      }
      if (sortGroup) sortGroup.addEventListener("click", (e) => {
        const btn = e.target.closest(".sort-btn");
        if (btn) setSort(btn.dataset.sort, true);
      });

      [search, cuisine, area, price, type, channel].forEach((el) => {
        if (!el) return;
        el.addEventListener("input", apply);
        el.addEventListener("change", apply);
      });
      if (reset) reset.addEventListener("click", () => {
        [search, cuisine, area, price, type, channel].forEach((el) => { if (el) el.value = ""; });
        apply();
      });

      markSort(sortMode);
      if (sortMode !== "ending") sortCards(sortMode); // default order already matches the server
      apply();
      document.addEventListener("langchange", renderChips); // chips follow the active language
    })();
  </script>
</Layout>
